# --- Database (SQLite, local file) ---
DATABASE_URL="file:./dev.db"

# --- Google Places (OPTIONAL) ---
# If left empty, the app works with OpenStreetMap only.
# Google Places gives ~$200/month of free credit (more than enough for
# freelance use). Used to enrich leads with phone, website, rating, reviews.
# Get a key: https://console.cloud.google.com/ (enable "Places API (New)")
GOOGLE_PLACES_API_KEY=""
