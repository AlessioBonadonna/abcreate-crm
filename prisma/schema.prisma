// Prisma schema for AB Create CRM — local SQLite, single-user.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String  @id @default(cuid())
  businessName String
  category     String
  city         String
  address      String?
  website      String?
  email        String?
  phone        String?
  openingHours String?
  latitude     Float?
  longitude    Float?
  source       String // "openstreetmap" | "google_places"
  enrichedVia  String? // e.g. "google_places" if completed via enrichment
  isChain      Boolean @default(false)
  dedupKey     String  @unique // prevents cross-run duplicates

  // --- site analysis ---
  httpStatus      Int?
  hasHttps        Boolean @default(false)
  pageTitle       String?
  metaDescription String?
  hasWhatsapp     Boolean @default(false)
  hasGoogleMaps   Boolean @default(false)
  hasContactForm  Boolean @default(false)
  hasContactPage  Boolean @default(false)
  hasEmailOnSite  Boolean @default(false)
  hasPhoneOnSite  Boolean @default(false)
  hasSocialLinks  Boolean @default(false)
  textLength      Int     @default(0)
  loadError       String?
  analyzedAt      DateTime?

  // --- scoring & segmentation ---
  opportunityScore Int     @default(0)
  priority         String  @default("LOW") // HIGH / MEDIUM / LOW
  detectedProblems String? // JSON array of problem strings
  segment          String?
  suggestedMessage String? // cached WhatsApp variant (full set generated on demand)

  // --- CRM ---
  status      String    @default("Da contattare")
  channel     String? // WhatsApp / Email / Telefono / Di persona / Instagram
  nextFollowUp DateTime?
  notes       String?
  activities  Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([city])
  @@index([category])
  @@index([priority])
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String // "messaggio_inviato" | "risposta" | "nota" | "cambio_stato"
  content   String?
  createdAt DateTime @default(now())

  @@index([leadId])
}

model SearchRun {
  id         String   @id @default(cuid())
  cities     String // JSON array
  categories String // JSON array
  totalFound Int      @default(0)
  newLeads   Int      @default(0)
  status     String   @default("running") // running | done | error
  progress   Int      @default(0) // 0-100
  message    String? // current step / error message
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  segment   String?
  channel   String? // WhatsApp | Email
  subject   String? // for email
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}
